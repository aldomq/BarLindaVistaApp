# ==========================================================
#  Configuracion del backend  -  copia este archivo como .env
# ==========================================================

# Entorno y puerto
PORT=4000

# Origenes permitidos para CORS (separados por coma). * = todos.
CORS_ORIGIN=*

# ----------------------------------------------------------
#  BASE DE DATOS PostgreSQL
#  AWS RDS te da el "endpoint", usuario, contrasena y nombre de la BD.
# ----------------------------------------------------------
# Ejemplo AWS RDS:
#   DB_HOST=lindavista.xxxxxxxx.us-east-1.rds.amazonaws.com
#   DB_SSL=require
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lindavista
DB_USER=postgres
DB_PASSWORD=postgres

# SSL: usa "require" para AWS RDS, Neon o Supabase. "disable" solo en local.
DB_SSL=disable

# Sembrar datos de ejemplo al arrancar si la base esta vacia (true/false)
SEED_ON_START=false
